<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>学情雷达 - 注册</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body class="min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md transform transition-all">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl mb-4 shadow-lg">
                <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <h1 class="text-3xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">学情雷达</h1>
            <p class="text-gray-500 mt-2">创建新账号</p>
        </div>

        <div class="space-y-4">
            <!-- 角色选择 -->
            <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">角色</label>
                <select id="roleSelect" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition bg-white">
                    <option value="student">学生</option>
                    <option value="teacher">教师</option>
                </select>
            </div>

            <!-- 姓名 -->
            <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">姓名</label>
                <input type="text" id="name" placeholder="请输入真实姓名" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
            </div>

            <!-- 手机号 -->
            <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">手机号</label>
                <input type="tel" id="phone" placeholder="请输入手机号" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
            </div>

            <!-- 密码 -->
            <div>
                <label class="block text-gray-700 text-sm font-medium mb-2">密码</label>
                <input type="password" id="password" placeholder="请设置密码" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition">
            </div>

            <!-- 学生专属字段：班级 -->
            <div id="studentFields">
                <label class="block text-gray-700 text-sm font-medium mb-2">班级</label>
                <select id="classSelect" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition bg-white">
                    <option value="">加载班级中...</option>
                </select>
            </div>

            <!-- 教师专属字段：学校（目前只有一所，显示固定信息） -->
            <div id="teacherFields" class="hidden">
                <div class="bg-gray-50 p-3 rounded-xl text-gray-600 text-sm">
                    📚 学校：智学中学（默认）
                </div>
            </div>

            <button id="registerBtn" class="btn btn-primary w-full py-3 text-base">注 册</button>
        </div>

        <div id="message" class="mt-4 text-center text-sm text-red-500"></div>

        <div class="mt-6 text-center">
            <a href="/login" class="text-indigo-600 hover:text-indigo-700 transition">已有账号？去登录</a>
        </div>
    </div>

    <script>
        // 角色切换
        const roleSelect = document.getElementById('roleSelect');
        const studentFields = document.getElementById('studentFields');
        const teacherFields = document.getElementById('teacherFields');
        
        roleSelect.addEventListener('change', () => {
            if (roleSelect.value === 'student') {
                studentFields.classList.remove('hidden');
                teacherFields.classList.add('hidden');
                loadClasses();
            } else {
                studentFields.classList.add('hidden');
                teacherFields.classList.remove('hidden');
            }
        });

        // 加载班级列表（公开API）
        async function loadClasses() {
            const classSelect = document.getElementById('classSelect');
            try {
                const res = await fetch('/api/public/classes');
                const classes = await res.json();
                classSelect.innerHTML = '<option value="">请选择班级</option>';
                classes.forEach(cls => {
                    const option = document.createElement('option');
                    option.value = cls.id;
                    option.textContent = cls.name;
                    classSelect.appendChild(option);
                });
            } catch (e) {
                console.error('加载班级失败', e);
                classSelect.innerHTML = '<option value="">暂无班级，请联系教师</option>';
            }
        }

        // 注册按钮点击
        document.getElementById('registerBtn').onclick = async () => {
            const name = document.getElementById('name').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const password = document.getElementById('password').value.trim();
            const role = roleSelect.value;
            const msgDiv = document.getElementById('message');

            if (!name || !phone || !password) {
                msgDiv.innerHTML = '请填写完整信息';
                return;
            }

            const body = { name, phone, password, role };
            if (role === 'student') {
                const classId = document.getElementById('classSelect').value;
                if (!classId) {
                    msgDiv.innerHTML = '请选择班级';
                    return;
                }
                body.class_id = parseInt(classId);
            }

            const res = await fetch('/api/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const data = await res.json();

            if (res.ok && data.success) {
                msgDiv.innerHTML = '<span class="text-green-600">注册成功，即将跳转登录...</span>';
                setTimeout(() => window.location.href = '/login', 2000);
            } else {
                msgDiv.innerHTML = data.error || '注册失败';
            }
        };

        // 初始化：默认学生，加载班级
        if (roleSelect.value === 'student') {
            loadClasses();
        }
    </script>
</body>
</html>