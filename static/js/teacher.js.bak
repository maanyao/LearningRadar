// teacher.js
let statusChart = null;
let activityChart = null;
let currentPanel = 'students';
let allTasks = [];
let autoRefreshInterval = null;
let currentClassId = null;
let teacherName = '';

// 辅助函数：格式化日期
function formatDateTime(dateStr) {
    if (!dateStr) return '';
    if (typeof dateStr === 'string') return dateStr.slice(0, 19);
    return dateStr;
}

// 防XSS
function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
    });
}

// 页面加载完成后的初始化
document.addEventListener('DOMContentLoaded', async () => {
    await loadTeacherInfo();
    await loadClasses();
    await loadStudents();
    await loadClassReport();
    startAutoRefresh();
    bindAllEvents();
});

// 绑定所有事件
function bindAllEvents() {
    // 标签页切换
    document.getElementById('tabStudents')?.addEventListener('click', () => switchPanel('students'));
    document.getElementById('tabTasks')?.addEventListener('click', () => switchPanel('tasks'));
    document.getElementById('tabClassManage')?.addEventListener('click', () => switchPanel('classManage'));
    document.getElementById('tabReport')?.addEventListener('click', () => switchPanel('report'));

    // 班级切换
    const classSelector = document.getElementById('classSelector');
    if (classSelector) {
        classSelector.addEventListener('change', async (e) => {
            currentClassId = parseInt(e.target.value);
            if (currentClassId) {
                loadStudents(currentClassId);
                loadClassStudents(currentClassId);
                loadClassReport(currentClassId);
            }
        });
    }

    // 一键提醒
    document.getElementById('sendReminderBtn')?.addEventListener('click', sendReminder);
    // 退出登录
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/login';
    });
    // 刷新学生状态
    document.getElementById('refreshStudents')?.addEventListener('click', () => loadStudents());
    // 班级管理中的添加学生
    document.getElementById('addStudentBtn')?.addEventListener('click', () => openStudentModal());
    document.getElementById('cancelStudentModal')?.addEventListener('click', () => studentModal.classList.add('hidden'));
    document.getElementById('saveStudentBtn')?.addEventListener('click', saveStudent);
    // 新建班级
    document.getElementById('createClassBtn')?.addEventListener('click', () => classModal.classList.remove('hidden'));
    document.getElementById('cancelClassModal')?.addEventListener('click', () => classModal.classList.add('hidden'));
    document.getElementById('saveClassBtn')?.addEventListener('click', createClass);
    // 任务管理相关
    document.getElementById('newTaskBtn')?.addEventListener('click', openTaskModal);
    document.getElementById('cancelModal')?.addEventListener('click', () => taskModal.classList.add('hidden'));
    document.getElementById('saveTaskBtn')?.addEventListener('click', saveTask);
    document.getElementById('addStepBtn')?.addEventListener('click', () => addStep());
    document.getElementById('applyFilter')?.addEventListener('click', () => applyTaskFilter());
    // 关闭报告模态框
    document.getElementById('closeReport')?.addEventListener('click', () => reportModal.classList.add('hidden'));
    // 导出报告按钮（班级报告面板）
    document.getElementById('exportReportBtn')?.addEventListener('click', exportReportCSV);
    // 状态筛选
    document.getElementById('statusFilter')?.addEventListener('change', filterStudentTable);
    // 批量导入任务
    document.getElementById('importTasksBtn')?.addEventListener('click', () => document.getElementById('tasksFileInput').click());
    document.getElementById('tasksFileInput')?.addEventListener('change', importTasksFile);
    // 批量导入学生（在班级管理面板中绑定，但动态绑定已在loadClassStudents中完成，这里也绑定一次确保）
    document.getElementById('importStudentsBtn')?.addEventListener('click', () => document.getElementById('studentsFileInput').click());
    document.getElementById('studentsFileInput')?.addEventListener('change', importStudentsFile);
}

// 面板切换
function switchPanel(panel) {
    const studentsPanel = document.getElementById('studentsPanel');
    const tasksPanel = document.getElementById('tasksPanel');
    const classManagePanel = document.getElementById('classManagePanel');
    const reportPanel = document.getElementById('reportPanel');
    const tabs = {
        students: document.getElementById('tabStudents'),
        tasks: document.getElementById('tabTasks'),
        classManage: document.getElementById('tabClassManage'),
        report: document.getElementById('tabReport')
    };

    [studentsPanel, tasksPanel, classManagePanel, reportPanel].forEach(p => p?.classList.add('hidden'));
    Object.values(tabs).forEach(tab => {
        if (tab) {
            tab.classList.remove('border-indigo-600', 'text-indigo-600');
            tab.classList.add('border-transparent');
        }
    });

    if (panel === 'students') {
        studentsPanel?.classList.remove('hidden');
        tabs.students?.classList.add('border-indigo-600', 'text-indigo-600');
        currentPanel = 'students';
    } else if (panel === 'tasks') {
        tasksPanel?.classList.remove('hidden');
        tabs.tasks?.classList.add('border-indigo-600', 'text-indigo-600');
        currentPanel = 'tasks';
        loadTasks();
    } else if (panel === 'classManage') {
        classManagePanel?.classList.remove('hidden');
        tabs.classManage?.classList.add('border-indigo-600', 'text-indigo-600');
        currentPanel = 'classManage';
        if (currentClassId) loadClassStudents(currentClassId);
    } else if (panel === 'report') {
        reportPanel?.classList.remove('hidden');
        tabs.report?.classList.add('border-indigo-600', 'text-indigo-600');
        currentPanel = 'report';
        if (currentClassId) loadClassReport(currentClassId);
        else {
            document.getElementById('reportClassName').innerText = '班级报告';
            document.getElementById('reportStudentCount').innerText = '0';
        }
    }
}

// 加载教师信息
async function loadTeacherInfo() {
    const res = await fetch('/api/current_user');
    if (res.status === 401) {
        window.location.href = '/login';
        return;
    }
    const user = await res.json();
    teacherName = user.name;
    document.getElementById('teacherInfo').innerText = `欢迎，${teacherName}`;
}

// 加载班级列表
async function loadClasses() {
    const res = await fetch('/api/teacher/classes');
    if (res.status === 403) {
        window.location.href = '/login';
        return;
    }
    const classes = await res.json();
    const selector = document.getElementById('classSelector');
    selector.innerHTML = '<option value="">请选择班级</option>';
    if (classes.length === 0) {
        selector.innerHTML += '<option value="" disabled>暂无班级，请先创建</option>';
        return;
    }
    classes.forEach(cls => {
        const option = document.createElement('option');
        option.value = cls.id;
        option.textContent = cls.name;
        selector.appendChild(option);
    });
    if (classes.length > 0) {
        selector.value = classes[0].id;
        currentClassId = classes[0].id;
        loadStudents(currentClassId);
        loadClassStudents(currentClassId);
        loadClassReport(currentClassId);
    }
}

// 加载学生进度
async function loadStudents(classId = currentClassId) {
    if (!classId) {
        const tbody = document.getElementById('studentTableBody');
        if (tbody) tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4">请先选择一个班级</td></tr>';
        return;
    }
    const res = await fetch(`/api/students_progress?class_id=${classId}`);
    if (res.status === 403) {
        window.location.href = '/login';
        return;
    }
    const students = await res.json();
    renderStudentTable(students);
    updateChart(students);
}

// 渲染学生表格
function renderStudentTable(students) {
    const tbody = document.getElementById('studentTableBody');
    if (!tbody) return;
    tbody.innerHTML = '';
    if (students.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4">暂无学生</td></tr>';
        return;
    }
    students.forEach(s => {
        const row = tbody.insertRow();
        row.innerHTML = `
            <td class="py-2 px-4">${escapeHtml(s.name)}</td>
            <td class="py-2 px-4">${escapeHtml(s.task_name || '-')}</td>
            <td class="py-2 px-4">${s.current_step}/${s.total_steps}</td>
            <td class="py-2 px-4"><span class="badge badge-${s.status}">${s.status === 'normal' ? '正常' : s.status === 'stuck' ? '卡住' : '超前'}</span></td>
            <td class="py-2 px-4">${formatDateTime(s.last_step_time)}</td>
            <td class="py-2 px-4">
                <button class="change-status btn btn-outline text-xs py-1 px-2" data-id="${s.id}" data-status="${s.status}">修改状态</button>
                <button class="assign-task btn btn-info text-xs py-1 px-2 ml-1" data-id="${s.id}">分配任务</button>
                <button class="send-reminder btn btn-warning text-xs py-1 px-2 ml-1" data-id="${s.id}">推送提醒</button>
            </td>
        `;
    });
    // 修改状态
    document.querySelectorAll('.change-status').forEach(btn => {
        btn.addEventListener('click', async () => {
            const studentId = btn.dataset.id;
            const newStatus = prompt('请输入新状态 (normal/stuck/ahead):', btn.dataset.status);
            if (newStatus && ['normal','stuck','ahead'].includes(newStatus)) {
                await fetch('/api/update_student_status', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ student_id: studentId, status: newStatus })
                });
                loadStudents();
            }
        });
    });
    // 分配任务
    document.querySelectorAll('.assign-task').forEach(btn => {
        btn.addEventListener('click', async () => {
            const studentId = btn.dataset.id;
            const tasksRes = await fetch(`/api/tasks/available?student_id=${studentId}`);
            const tasks = await tasksRes.json();
            if (tasks.length === 0) {
                alert('该学生已完成所有任务，或已有未完成任务，无法分配新任务。');
                return;
            }
            const taskOptions = tasks.map(t => `${t.id}: ${t.name} (${t.type === 'basic' ? '基础' : '进阶'})`).join('\n');
            const taskId = prompt(`选择任务ID:\n${taskOptions}`);
            if (!taskId) return;
            const assignRes = await fetch('/api/assign_task', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ student_id: studentId, task_id: parseInt(taskId) })
            });
            const data = await assignRes.json();
            if (assignRes.ok) {
                alert('任务已分配');
                loadStudents();
            } else {
                alert(data.error || '分配失败');
            }
        });
    });
    // 单独推送提醒
    document.querySelectorAll('.send-reminder').forEach(btn => {
        btn.addEventListener('click', async () => {
            const studentId = btn.dataset.id;
            const res = await fetch('/api/send_reminder_to_student', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ student_id: studentId })
            });
            if (res.ok) alert('提醒已发送');
            else alert('发送失败');
        });
    });
}

// 更新状态饼图
function updateChart(students) {
    const counts = { normal: 0, stuck: 0, ahead: 0 };
    students.forEach(s => {
        if (s.status === 'normal') counts.normal++;
        else if (s.status === 'stuck') counts.stuck++;
        else if (s.status === 'ahead') counts.ahead++;
    });
    const ctx = document.getElementById('statusChart');
    if (!ctx) return;
    if (statusChart) statusChart.destroy();
    statusChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['正常', '卡住', '超前'],
            datasets: [{ data: [counts.normal, counts.stuck, counts.ahead], backgroundColor: ['#10b981', '#ef4444', '#3b82f6'] }]
        },
        options: { responsive: true, maintainAspectRatio: true }
    });
}

// 班级管理面板：加载班级学生列表
async function loadClassStudents(classId) {
    if (!classId) {
        const tbody = document.getElementById('classStudentTableBody');
        if (tbody) tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4">请先选择一个班级</td></tr>';
        return;
    }
    const res = await fetch(`/api/classes/${classId}/students`);
    if (res.status === 403) {
        window.location.href = '/login';
        return;
    }
    const students = await res.json();
    const tbody = document.getElementById('classStudentTableBody');
    tbody.innerHTML = '';
    if (students.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4">暂无学生，点击添加</td></tr>';
        return;
    }
    students.forEach(s => {
        const row = tbody.insertRow();
        row.innerHTML = `
            <td class="py-2 px-4">${escapeHtml(s.name)}</td>
            <td class="py-2 px-4">${escapeHtml(s.phone)}</td>
            <td class="py-2 px-4">${formatDateTime(s.last_active)}</td>
            <td class="py-2 px-4">
                <button class="edit-student btn btn-info text-xs py-1 px-2" data-id="${s.id}" data-name="${s.name}" data-phone="${s.phone}">编辑</button>
                <button class="delete-student btn btn-danger text-xs py-1 px-2 ml-1" data-id="${s.id}">删除</button>
            </td>
        `;
    });
    // 编辑/删除事件
    document.querySelectorAll('.edit-student').forEach(btn => {
        btn.addEventListener('click', () => {
            openStudentModal(btn.dataset.id, btn.dataset.name, btn.dataset.phone);
        });
    });
    document.querySelectorAll('.delete-student').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (confirm('确定删除该学生吗？相关进度也会被清除。')) {
                const res = await fetch(`/api/students/${btn.dataset.id}`, { method: 'DELETE' });
                if (res.ok) {
                    alert('删除成功');
                    loadClassStudents(currentClassId);
                    loadStudents();
                } else {
                    alert('删除失败');
                }
            }
        });
    });
}

// 添加/编辑学生模态框
const studentModal = document.getElementById('studentModal');
const studentModalTitle = document.getElementById('studentModalTitle');
const editingStudentId = document.getElementById('editingStudentId');
const studentNameInput = document.getElementById('studentName');
const studentPhoneInput = document.getElementById('studentPhone');
const studentPasswordInput = document.getElementById('studentPassword');

function openStudentModal(id = null, name = '', phone = '') {
    if (id) {
        studentModalTitle.innerText = '编辑学生';
        editingStudentId.value = id;
        studentNameInput.value = name;
        studentPhoneInput.value = phone;
        studentPasswordInput.placeholder = '留空则密码不变';
        studentPasswordInput.value = '';
    } else {
        studentModalTitle.innerText = '添加学生';
        editingStudentId.value = '';
        studentNameInput.value = '';
        studentPhoneInput.value = '';
        studentPasswordInput.placeholder = '默认为123456';
        studentPasswordInput.value = '';
    }
    studentModal.classList.remove('hidden');
}

async function saveStudent() {
    const id = editingStudentId.value;
    const name = studentNameInput.value.trim();
    const phone = studentPhoneInput.value.trim();
    if (!name || !phone) {
        alert('请填写姓名和手机号');
        return;
    }
    let url, method, body;
    if (id) {
        url = `/api/students/${id}`;
        method = 'PUT';
        body = JSON.stringify({ name, phone });
    } else {
        url = '/api/students';
        method = 'POST';
        const password = studentPasswordInput.value.trim() || '123456';
        body = JSON.stringify({ name, phone, password, class_id: currentClassId });
    }
    const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body });
    if (res.ok) {
        alert(id ? '修改成功' : '添加成功');
        studentModal.classList.add('hidden');
        loadClassStudents(currentClassId);
        loadStudents();
    } else {
        const data = await res.json();
        alert(data.error || '操作失败');
    }
}

// 新建班级
const classModal = document.getElementById('classModal');
async function createClass() {
    const name = document.getElementById('className').value.trim();
    if (!name) {
        alert('请输入班级名称');
        return;
    }
    const res = await fetch('/api/classes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name })
    });
    if (res.ok) {
        alert('班级创建成功');
        classModal.classList.add('hidden');
        await loadClasses();
    } else {
        const data = await res.json();
        alert(data.error || '创建失败');
    }
}

// 一键提醒
async function sendReminder() {
    if (!currentClassId) {
        alert('请先选择一个班级');
        return;
    }
    const res = await fetch('/api/send_reminder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ class_id: currentClassId })
    });
    const data = await res.json();
    if (data.success) {
        alert(`✅ 已向 ${data.count} 位卡住学生发送提醒`);
    } else {
        alert('❌ 发送失败');
    }
}

// 班级报告导出 CSV
function exportReportCSV() {
    const rows = document.querySelectorAll('#taskCompletionTable tr');
    let csv = "任务名称,完成人数,完成率,平均进度\n";
    rows.forEach(row => {
        const cols = row.querySelectorAll('td');
        if (cols.length) {
            csv += `${cols[0].innerText},${cols[1].innerText},${cols[2].innerText},${cols[3].innerText}\n`;
        }
    });
    const blob = new Blob(["\uFEFF" + csv], {type: 'text/csv;charset=utf-8;'});
    const link = document.createElement('a');
    const url = URL.createObjectURL(blob);
    link.href = url;
    link.setAttribute('download', '班级报告.csv');
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
}

// 加载班级详细报告
async function loadClassReport(classId) {
    if (!classId) {
        document.getElementById('reportClassName').innerText = '班级报告';
        document.getElementById('reportStudentCount').innerText = '0';
        return;
    }
    try {
        const res = await fetch(`/api/class_detailed_report/${classId}`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();

        document.getElementById('reportClassName').innerText = `${data.class_name} - 班级报告`;
        document.getElementById('reportStudentCount').innerText = data.student_count;

        // 活跃度图表
        const ctx = document.getElementById('reportActivityChart').getContext('2d');
        if (window.reportChart) window.reportChart.destroy();
        window.reportChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.activity_trend.dates,
                datasets: [{ label: '活跃学生数', data: data.activity_trend.counts, borderColor: '#4f46e5', backgroundColor: 'rgba(79,70,229,0.1)', tension: 0.3, fill: true }]
            },
            options: { responsive: true, maintainAspectRatio: true, scales: { y: { beginAtZero: true, stepSize: 1 } } }
        });

        // 任务完成情况表
        const taskTable = document.getElementById('taskCompletionTable');
        taskTable.innerHTML = '';
        data.task_completion_stats.forEach(task => {
            const row = taskTable.insertRow();
            row.innerHTML = `<td class="py-2 px-4">${escapeHtml(task.task_name)}</td><td class="py-2 px-4">${task.completed_count}/${data.student_count}</td><td class="py-2 px-4">${task.completed_percent}%</td><td class="py-2 px-4">${task.avg_progress}%</td>`;
        });

        // 任务卡点汇总
        const stuckSummaryList = document.getElementById('taskStuckSummary');
        stuckSummaryList.innerHTML = '';
        if (data.task_stuck_summary.length === 0) {
            stuckSummaryList.innerHTML = '<li class="text-gray-500">暂无卡点数据</li>';
        } else {
            data.task_stuck_summary.forEach(item => {
                const li = document.createElement('li');
                li.innerHTML = `<strong>${escapeHtml(item.task_name)}</strong> - 步骤 ${item.step_index+1}: ${escapeHtml(item.step_desc)} (卡住 ${item.count} 人)`;
                stuckSummaryList.appendChild(li);
            });
        }

        // 当前卡住的学生
        const stuckRecordsDiv = document.getElementById('stuckRecordsList');
        stuckRecordsDiv.innerHTML = '';
        if (data.stuck_records.length === 0) {
            stuckRecordsDiv.innerHTML = '<div class="text-gray-500">暂无卡住学生</div>';
        } else {
            data.stuck_records.forEach(record => {
                const card = document.createElement('div');
                card.className = 'border rounded-lg p-3 bg-gray-50';
                card.innerHTML = `<div class="font-semibold">${escapeHtml(record.student_name)}</div><div class="text-sm text-gray-600">任务：${escapeHtml(record.task_name)}</div><div class="text-sm text-gray-600">步骤：${record.step_index+1} - ${escapeHtml(record.step_desc)}</div><div class="text-xs text-gray-500">卡住时间：${record.stuck_since}</div>${record.help_text ? `<div class="text-xs text-blue-600 mt-1">提示：${escapeHtml(record.help_text)}</div>` : ''}`;
                stuckRecordsDiv.appendChild(card);
            });
        }

        // 学生学习路径
        const learningPathsDiv = document.getElementById('studentLearningPaths');
        learningPathsDiv.innerHTML = '';
        if (data.student_learning_paths.length === 0) {
            learningPathsDiv.innerHTML = '<div class="text-gray-500">暂无学习数据</div>';
        } else {
            data.student_learning_paths.forEach(student => {
                const card = document.createElement('div');
                card.className = 'border rounded-lg p-3';
                card.innerHTML = `<div class="font-semibold text-lg">${escapeHtml(student.student_name)}</div><div class="mt-2 space-y-2">${student.learning_path.map(path => `<div class="flex justify-between items-center border-b pb-1"><span class="text-gray-700">📌 ${escapeHtml(path.task_name)}</span><span class="text-sm ${path.completed ? 'text-green-600' : 'text-orange-600'}">${path.status} (${path.progress})</span><span class="text-xs text-gray-500">${path.time}</span></div>`).join('')}</div>`;
                learningPathsDiv.appendChild(card);
            });
        }
    } catch (error) {
        console.error('加载班级报告失败:', error);
    }
}

// ========== 任务管理 ==========
async function loadTasks() {
    const res = await fetch('/api/tasks');
    allTasks = await res.json();
    applyTaskFilter();
}

function applyTaskFilter() {
    const knowledge = document.getElementById('filterKnowledge')?.value.toLowerCase() || '';
    const type = document.getElementById('filterType')?.value || '';
    let filtered = allTasks;
    if (knowledge) filtered = filtered.filter(t => (t.knowledge_point || '').toLowerCase().includes(knowledge));
    if (type) filtered = filtered.filter(t => t.type === type);
    renderTasks(filtered);
}

function renderTasks(tasks) {
    const container = document.getElementById('taskList');
    container.innerHTML = '';
    if (tasks.length === 0) {
        container.innerHTML = '<div class="text-center text-gray-500 py-8">暂无任务，点击上方按钮创建</div>';
        return;
    }
    tasks.forEach(task => {
        const card = document.createElement('div');
        card.className = 'border rounded-lg p-4 bg-gray-50';
        card.innerHTML = `<div class="flex justify-between items-start"><div><h3 class="text-lg font-semibold">${escapeHtml(task.name)}</h3><p class="text-sm text-gray-600">类型：${task.type === 'basic' ? '基础' : '进阶'} | 知识点：${escapeHtml(task.knowledge_point || '无')} | 步骤数：${task.steps.length}</p></div><div><button class="edit-task text-indigo-600 hover:underline mr-2" data-id="${task.id}">编辑</button><button class="delete-task text-red-600 hover:underline" data-id="${task.id}">删除</button><button class="view-steps text-gray-600 hover:underline ml-2" data-id="${task.id}">查看步骤</button></div></div>`;
        container.appendChild(card);
    });
    document.querySelectorAll('.edit-task').forEach(btn => btn.addEventListener('click', () => openEditModal(parseInt(btn.dataset.id))));
    document.querySelectorAll('.delete-task').forEach(btn => btn.addEventListener('click', async () => {
        if (confirm('确定删除该任务吗？删除后所有学生的进度也将被清除。')) {
            const res = await fetch(`/api/tasks/${btn.dataset.id}`, { method: 'DELETE' });
            if (res.ok) { alert('删除成功'); loadTasks(); } else alert('删除失败');
        }
    }));
    document.querySelectorAll('.view-steps').forEach(btn => btn.addEventListener('click', async () => {
        const res = await fetch(`/api/task_steps/${btn.dataset.id}`);
        const data = await res.json();
        const stepsText = data.steps.map((s, i) => `${i+1}. ${s} ${data.steps_config[i]?.help_text ? `(提示: ${data.steps_config[i].help_text})` : ''}`).join('\n');
        alert(`任务步骤：\n${stepsText}`);
    }));
}

// 任务模态框
const taskModal = document.getElementById('taskModal');
const stepsContainer = document.getElementById('stepsContainer');

function addStep(desc = '', needProof = false, helpText = '') {
    const div = document.createElement('div');
    div.className = 'step-item flex flex-col gap-2 mb-3 p-2 border rounded';
    div.innerHTML = `<div class="flex gap-2"><input type="text" class="step-desc flex-1 border rounded px-3 py-2" value="${escapeHtml(desc)}" placeholder="步骤描述"><label class="flex items-center"><input type="checkbox" class="step-need-proof mr-1" ${needProof ? 'checked' : ''}> 需要证明</label><button type="button" class="remove-step text-red-500 hover:text-red-700">删除</button></div><div><textarea class="step-help-text w-full border rounded px-3 py-2 text-sm" rows="2" placeholder="提示语（可选）">${escapeHtml(helpText)}</textarea></div>`;
    stepsContainer.appendChild(div);
    div.querySelector('.remove-step').addEventListener('click', () => div.remove());
}

function openTaskModal() {
    document.getElementById('modalTitle').innerText = '新建任务';
    document.getElementById('editingTaskId').value = '';
    document.getElementById('taskName').value = '';
    document.getElementById('taskType').value = 'basic';
    document.getElementById('taskKnowledge').value = '';
    stepsContainer.innerHTML = '';
    addStep('');
    taskModal.classList.remove('hidden');
}

async function saveTask() {
    const id = document.getElementById('editingTaskId').value;
    const name = document.getElementById('taskName').value.trim();
    const type = document.getElementById('taskType').value;
    const knowledge_point = document.getElementById('taskKnowledge').value.trim();
    const stepDivs = document.querySelectorAll('#stepsContainer .step-item');
    const steps = [], steps_config = [];
    stepDivs.forEach(div => {
        const desc = div.querySelector('.step-desc').value.trim();
        if (desc) {
            steps.push(desc);
            const needProof = div.querySelector('.step-need-proof').checked;
            const helpText = div.querySelector('.step-help-text').value.trim();
            steps_config.push({ need_proof: needProof, help_text: helpText });
        }
    });
    if (!name || steps.length === 0) {
        alert('请填写任务名称和至少一个步骤');
        return;
    }
    const url = id ? `/api/tasks/${id}` : '/api/tasks';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, type, knowledge_point, steps, steps_config })
    });
    if (res.ok) {
        alert(id ? '修改成功' : '创建成功');
        taskModal.classList.add('hidden');
        if (currentPanel === 'tasks') loadTasks();
    } else {
        alert('操作失败');
    }
}

function openEditModal(taskId) {
    const task = allTasks.find(t => t.id === taskId);
    if (!task) return;
    document.getElementById('modalTitle').innerText = '编辑任务';
    document.getElementById('editingTaskId').value = taskId;
    document.getElementById('taskName').value = task.name;
    document.getElementById('taskType').value = task.type;
    document.getElementById('taskKnowledge').value = task.knowledge_point || '';
    stepsContainer.innerHTML = '';
    task.steps.forEach((step, idx) => {
        const cfg = task.steps_config[idx] || {};
        addStep(step, cfg.need_proof || false, cfg.help_text || '');
    });
    taskModal.classList.remove('hidden');
}

// 批量导入任务
async function importTasksFile(e) {
    const file = e.target.files[0];
    if (!file) return;
    const formData = new FormData();
    formData.append('file', file);
    const res = await fetch('/api/tasks/batch_import', { method: 'POST', body: formData });
    if (res.ok) {
        alert('导入成功');
        loadTasks();
    } else {
        alert('导入失败');
    }
    e.target.value = null;
}

// 批量导入学生
async function importStudentsFile(e) {
    const file = e.target.files[0];
    if (!file) return;
    const formData = new FormData();
    formData.append('file', file);
    const res = await fetch('/api/students/batch_import', { method: 'POST', body: formData });
    if (res.ok) {
        alert('导入成功');
        loadClassStudents(currentClassId);
        loadStudents();
    } else {
        alert('导入失败');
    }
    e.target.value = null;
}

// 状态筛选
function filterStudentTable() {
    const filter = document.getElementById('statusFilter').value;
    const rows = document.querySelectorAll('#studentTableBody tr');
    rows.forEach(row => {
        const statusCell = row.cells[3];
        if (filter === 'all') row.style.display = '';
        else if (statusCell.innerText.includes(getStatusText(filter))) row.style.display = '';
        else row.style.display = 'none';
    });
}
function getStatusText(status) {
    if (status === 'normal') return '正常';
    if (status === 'stuck') return '卡住';
    if (status === 'ahead') return '超前';
    return '';
}

// 自动刷新
function startAutoRefresh() {
    if (autoRefreshInterval) clearInterval(autoRefreshInterval);
    autoRefreshInterval = setInterval(() => {
        if (currentPanel === 'students' && currentClassId) loadStudents();
    }, 10000);
}